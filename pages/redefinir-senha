<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexus - Redefinir senha</title>
  <link rel="stylesheet" href="../css/style.css?v=senha-termos-1">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="../js/supabase.js?v=senha-termos-1"></script>
</head>
<body>
  <main class="login-container">
    <section class="login-card">
      <div class="logo-area">
        <img src="../assets/logo.png" alt="Logo Nexus" class="logo">
        <h1>NEXUS</h1>
        <p class="marca"><span>JRT</span>ecnologia</p>
      </div>
      <form id="redefinirSenhaForm">
        <div class="input-group"><label>Nova senha</label><input id="novaSenha" type="password"></div>
        <div class="input-group"><label>Confirmar senha</label><input id="confirmarSenha" type="password"></div>
        <button type="submit">Redefinir senha</button>
      </form>
    </section>
  </main>
<script>
const params = new URLSearchParams(window.location.search);
const token = params.get("token");
if (!token) {
  alert("Link inválido.");
  window.location.href = "../index.html";
}

document.getElementById("redefinirSenhaForm").addEventListener("submit", async (event) => {
  event.preventDefault();
  const novaSenha = document.getElementById("novaSenha").value.trim();
  const confirmarSenha = document.getElementById("confirmarSenha").value.trim();
  if (!novaSenha || !confirmarSenha) return alert("Preencha as senhas.");
  if (novaSenha.length < 6) return alert("A senha precisa ter pelo menos 6 caracteres.");
  if (novaSenha !== confirmarSenha) return alert("As senhas não conferem.");

  const { data: solicitacao, error: erroBusca } = await supabaseClient
    .from("nexus_redefinicoes_senha")
    .select("*")
    .eq("token", token)
    .in("status", ["pendente", "pendente_envio", "enviado"])
    .maybeSingle();

  if (erroBusca || !solicitacao) return alert("Link inválido ou já utilizado.");
  if (solicitacao.expira_em && new Date(solicitacao.expira_em) < new Date()) return alert("Link expirado.");

  const { data: usuarioAtualizado, error: erroSenha } = await supabaseClient
    .from("nexus_usuarios")
    .update({ senha: novaSenha, primeiro_acesso: false, alterar_senha: false })
    .eq("id", solicitacao.usuario_id)
    .select()
    .single();

  if (erroSenha) return alert("Erro ao redefinir senha: " + erroSenha.message);

  await supabaseClient
    .from("nexus_redefinicoes_senha")
    .update({ status: "utilizada", utilizada_em: new Date().toISOString() })
    .eq("id", solicitacao.id);

  localStorage.setItem("nexus_usuario", JSON.stringify(usuarioAtualizado));
  alert("Senha redefinida com sucesso.");
  window.location.href = "dashboard-master.html";
});
</script>
</body>
</html>
